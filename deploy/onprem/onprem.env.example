# FoldForge on-prem — copy to .env and fill in. Used by docker-compose.onprem.yml.
# .env is gitignored — never commit real secrets.

# --- Delivery (model B: customer's internal Harbor) ---------------------------
# Your Harbor project that holds the FoldForge images (push them with
# scripts/push-to-harbor.sh first). Include the project path, no trailing slash.
FOLDFORGE_REGISTRY=harbor.your-company.internal/foldforge
# The released version to run. NEVER use 'latest' on-prem — pin a reproducible tag so
# you and support are debugging the exact same build.
FOLDFORGE_VERSION=v0.1.0

# --- Stack secrets ------------------------------------------------------------
# Postgres password for the stack's own database (compose-internal only).
POSTGRES_PASSWORD=change-me-to-a-strong-value
# Gateway static admin bearer token. Clients send it as `Authorization: Bearer <token>`.
API_TOKEN=change-me-to-a-strong-value
# Object store (MinIO) creds — gateway artifact download + sidecar artifact upload.
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me-to-a-strong-value
R2_BUCKET=foldforge
R2_REGION=auto

# --- Published ports (bind behind the customer's own ingress/VPN) -------------
GATEWAY_HOST_PORT=18080
CONSOLE_HOST_PORT=13000

# --- Runner: mock (default, no GPU) vs real -----------------------------------
# Leave RUNNER=mock to run the platform demoable with synthetic outputs (no GPU nodes
# needed). To switch to REAL inference, set FOLDFORGE_RUNNER= (empty) and point each
# SIDECAR_* at a GPU node running that sidecar (see RUNPOD-DEPLOY.md / gpu compose).
FOLDFORGE_RUNNER=mock
# SIDECAR_RFDIFFUSION=http://gpu-node-1:50061
# SIDECAR_PROTEINMPNN=http://gpu-node-1:50062
# SIDECAR_BOLTZ=http://gpu-node-2:50063
# SIDECAR_AF2=http://gpu-node-2:50064

# --- Per-user keys + billing (optional) ---------------------------------------
API_KEYS_ENABLED=false
BILLING_ENABLED=false
PRICE_PER_STEP=10

# --- License (on-prem, delivery model B) --------------------------------------
# A valid signed license key is required to start the control plane. The vendor issues
# it (see LICENSE-OPS.md). Set to the exact key string they gave you.
LICENSE_ENFORCED=true
LICENSE_KEY=paste-the-signed-license-key-from-your-vendor
