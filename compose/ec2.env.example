# Copy to .env and fill in. Used by docker-compose.ec2.yml.
# This file (.env) is gitignored — never commit real secrets.

# Postgres password for the stack's own database (compose-internal only).
POSTGRES_PASSWORD=change-me-to-a-strong-value

# Gateway static admin bearer token. Any non-empty value; clients send it as
# `Authorization: Bearer <API_TOKEN>`. Keep it secret.
API_TOKEN=change-me-to-a-strong-value

# Host port the gateway is published on (avoids 80/443/8080 on a shared box).
# Open this port in the EC2 security group only if you want external access.
GATEWAY_HOST_PORT=18080
# Host port the console (web UI) is published on. Reach it via an SSH tunnel.
CONSOLE_HOST_PORT=13000
# Image tags to deploy in pull mode (default: latest). Set to sha-<full-commit>
# to pin an immutable build, e.g. ORCHESTRATOR_TAG=sha-abc123...
ORCHESTRATOR_TAG=latest
GATEWAY_TAG=latest
CONSOLE_TAG=latest
# Object store (MinIO) creds — used by BOTH the gateway (artifact download) and the
# orchestrator mock runner (synthetic artifact upload), so the console 3D viewer +
# download work with no GPU. MinIO is internal-only (no host port). Any non-empty
# values; keep them secret.
MINIO_ROOT_USER=change...n
MINIO_ROOT_PASSWORD=change...n
R2_BUCKET=foldforge
R2_REGION=auto
