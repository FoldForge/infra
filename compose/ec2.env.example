# Copy to .env and fill in. Used by docker-compose.ec2.yml.
# This file (.env) is gitignored — never commit real secrets.

# Postgres password for the stack's own database (compose-internal only).
POSTGRES_PASSWORD=change-me-to-a-strong-value

# Gateway static admin bearer token. Any non-empty value; clients send it as
# `Authorization: Bearer <API_TOKEN>`. Keep it secret.
API_TOKEN=change-me-to-a-strong-value

# Host port the gateway is published on (avoids 80/443/8080 on a shared box).
# Open this port in the EC2 security group only if you want external access.
GATEWAY_HOST_PORT=18080
